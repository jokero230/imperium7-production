# ═════════════════════════════════════════════════════════════
# IMPERIUM 7™ — ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════

# ─── DEPLOYMENT ENVIRONMENT ───────────────────────────────────
NODE_ENV=production
DEPLOYMENT_ENV=production
APP_NAME=imperium-hub
APP_VERSION=1.0.0

# ─── CORE DOMAIN & NETWORKING ─────────────────────────────────
DOMAIN=deputatai.com
WWW_DOMAIN=www.deputatai.com
API_DOMAIN=api.deputatai.com
DASHBOARD_DOMAIN=dashboard.deputatai.com
ML_DOMAIN=ml.deputatai.com
WORKSPACE_DOMAIN=workspace.deputatai.com

# ─── TRAEFIK & REVERSE PROXY ──────────────────────────────────
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=your-secure-password-here
TRAEFIK_API_ENTRYPOINT=traefik
ACME_EMAIL=admin@deputatai.com
LETS_ENCRYPT_STAGING=false
SECURE_PROTOCOL=https
HSTS_MAX_AGE=31536000

# ─── DATABASE CONFIGURATION ───────────────────────────────────
# MongoDB
MONGODB_HOST=imperium-mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=imperium
MONGODB_USER=imperium_user
MONGODB_PASSWORD=your-secure-mongo-password
MONGO_URI=mongodb://imperium_user:your-secure-mongo-password@imperium-mongodb:27017/imperium?authSource=admin
MONGODB_REPLICA_SET=rs0

# PostgreSQL (optional, for future use)
POSTGRES_HOST=imperium-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=imperium
POSTGRES_USER=imperium_user
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_URI=postgresql://imperium_user:your-secure-postgres-password@imperium-postgres:5432/imperium

# ─── REDIS CONFIGURATION ──────────────────────────────────────
REDIS_HOST=imperium-redis
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@imperium-redis:6379
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ─── API KEYS & SECRETS ───────────────────────────────────────
JWT_SECRET=your-super-secure-jwt-secret-key-min-32-chars
JWT_EXPIRY=7d
ENCRYPTION_KEY=your-32-byte-encryption-key-in-base64
SESSION_SECRET=your-secure-session-secret

# ─── STRIPE INTEGRATION ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRODUCT_BASIC=prod_basic_sku
STRIPE_PRODUCT_PRO=prod_pro_sku
STRIPE_PRODUCT_AGENCY=prod_agency_sku

# ─── AI & ML APIs ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk_or_your_openrouter_key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_GEMINI_API_KEY=your-google-gemini-key

# ─── HERMES AGENT CONFIGURATION ───────────────────────────────
HERMES_AGENT_PORT=5000
HERMES_AGENT_WORKERS=4
HERMES_AGENT_TIMEOUT=300
HERMES_AGENT_MAX_RETRIES=3
HERMES_AGENT_FAILOVER=true
HERMES_AGENT_LOG_LEVEL=INFO
HERMES_MODEL=anthropic/claude-3.5-sonnet
HERMES_MAX_TOKENS=16000
HERMES_TEMPERATURE=0.7

# ─── WORKSPACE & FRONTEND ─────────────────────────────────────
REACT_APP_API_URL=https://api.deputatai.com
REACT_APP_WORKSPACE_URL=https://workspace.deputatai.com
NEXT_PUBLIC_API_URL=https://api.deputatai.com
NEXT_PUBLIC_WS_URL=wss://api.deputatai.com/ws
NEXT_PUBLIC_ANALYTICS=true

# ─── AGENT ORCHESTRATION ──────────────────────────────────────
FOA1_ENABLED=true
SOA1_ENABLED=true
TSA1_ENABLED=true
SFA1_ENABLED=true
OPA1_ENABLED=true
OMA1_ENABLED=true
AGENT_CONSENSUS_MODE=CONSULT
AGENT_AUTO_FAILOVER=true
AGENT_CIRCUIT_BREAKER_THRESHOLD=5

# ─── DEFENSE & SECURITY ───────────────────────────────────────
DEFENSE_OS_ENABLED=true
REGSHIELD_OS_ENABLED=true
KILL_SWITCH_ENABLED=true
DEFENSE_MASTER_KEY=your-defense-master-key-secret
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
MAX_COST_CAP_USD=100
ANOMALY_DETECTION_THRESHOLD=0.85

# ─── MONITORING & OBSERVABILITY ───────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
JAEGER_ENABLED=true
ELK_STACK_ENABLED=false
LOG_LEVEL=info
DEBUG=false

# ─── BACKUPS & PERSISTENCE ────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=imperium-backups
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_ACCESS_KEY=your-aws-access-key
BACKUP_S3_SECRET_KEY=your-aws-secret-key

# ─── SMTP & NOTIFICATIONS ─────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@deputatai.com
SMTP_FROM_NAME=Imperium Hub
ALERT_EMAIL=alerts@deputatai.com

# ─── HETZNER CLOUD API (Infrastructure) ───────────────────────
HETZNER_API_TOKEN=your-hetzner-api-token
HETZNER_REGION=fsn1
HETZNER_IMAGE=ubuntu-24.04
HETZNER_SERVER_TYPE=cx32

# ─── DOCKER REGISTRY ──────────────────────────────────────────
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password
DOCKER_IMAGE_PREFIX=jokero230/imperium

# ─── HEALTH CHECK ─────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
READINESS_PROBE_DELAY=5
LIVENESS_PROBE_DELAY=10

# ─── PERFORMANCE TUNING ───────────────────────────────────────
NODE_MAX_OLD_SPACE_SIZE=2048
UVICORN_WORKERS=4
GUNICORN_WORKERS=4
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=20

# ─── FEATURE FLAGS ────────────────────────────────────────────
FEATURE_FUSION_CORE=true
FEATURE_VOICE_OS=true
FEATURE_OMNI_CONTEXT=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_WHITE_LABEL=false

# ─── COMPLIANCE & AUDIT ───────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
GDPR_MODE=true
DATA_RESIDENCY=EU
COMPLIANCE_LEVEL=HIGH

# ─── DEVELOPMENT OVERRIDES (dev env only) ────────────────────
# Uncomment when NODE_ENV=development
# DEBUG=*
# SKIP_AUTH=false
# MOCK_SERVICES=false
